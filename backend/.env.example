# Server Configuration
PORT=3000
NODE_ENV=production

# Database Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/<dbname>?appName=Cluster0

# JWT Authentication
JWT_SECRET=your_strong_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_strong_refresh_secret_here_min_32_chars

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=your_email_from_address@domain.com
EMAIL_FROM_NAME=Your App Name

# Client URL
CLIENT_URL=https://yourclientdomain.com or http://localhost:

# File Uploads (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Security (Arcjet)
ARCJET_KEY=ajkey_your_arcjet_key_here
ARCJET_ENV=production